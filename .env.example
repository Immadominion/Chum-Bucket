# ==============================================
# Chumbucket Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!

# ==============================================
# SOLANA NETWORK CONFIGURATION
# ==============================================
# Network selection: 'devnet' or 'mainnet-beta'
SOLANA_NETWORK=devnet

# RPC URLs (use private RPC for production)
# For devnet testing:
SOLANA_RPC_URL=https://api.devnet.solana.com
# For mainnet production (use Helius, QuickNode, or similar):
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# Or use network-specific URLs:
# SOLANA_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY
# SOLANA_MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Helius API key for SNS domain lookups (optional but recommended)
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ==============================================
# ARENA / PREDICTION SETTLEMENT
# ==============================================
# Read-only backend that lists fixtures and pot state. Staking/claiming signs
# directly through MWA against the chumbucket_arena program.
# For a physical Android device over USB, run `adb reverse tcp:8787 tcp:8787`
# and use http://127.0.0.1:8787 locally. For production, use the deployed
# HTTPS backend URL.
ARENA_BACKEND_URL=http://localhost:8787

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ==============================================
# LEGACY PRIVY CONFIGURATION (optional, for backward compatibility)
# ==============================================
# These are only needed if you still have users on Privy auth
# APP_ID=YOUR_PRIVY_APP_ID_HERE
# APP_SECRET=YOUR_PRIVY_APP_SECRET_HERE
# PRIVY_API_URL=https://api.privy.io/v1
